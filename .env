# Copie este arquivo para o mesmo diretório do sincronizador com o nome: .env
# Depois substitua os valores abaixo pelas conexões reais.
# Importante: não envie este arquivo preenchido por e-mail, WhatsApp ou repositório Git.


SANKHYA_AUTH_URL=https://api.sankhya.com.br/authenticate
SANKHYA_VIEW_URL=https://api.sankhya.com.br/gateway/v1/mge/service.sbr?serviceName=CRUDServiceProvider.loadView&outputType=json
SANKHYA_VIEW_NAME=VIEW CRIADA NO SISTEMA

SANKHYA_CLIENT_ID="*******"
SANKHYA_CLIENT_SECRET="*******"
SANKHYA_APP_TOKEN="*******"

DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER="IP"
DB_NAME="BANCO"
DB_USER="USUARIO"
DB_PASSWORD="SENHA"
DB_SCHEMA="SCHEMA"
DB_TABLE="TABELA"

SCHEDULE_TIMES=06:00,12:00,16:34
SCHEDULER_TIMEZONE=America/Sao_Paulo

NUNOTA_MIN=0
NUNOTA_MAX=3000000
NUNOTA_STEP=50000
BATCH_SIZE=1000
REQUEST_SLEEP_SECONDS=0.2
LOG_LEVEL=INFO
